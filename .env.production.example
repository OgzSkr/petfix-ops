# Production deploy profili — VPS yalnızca HzlMrktOps
# full = tüm modüller (local Mac); ops-only = webhook + ops panel
DEPLOY_PROFILE=ops-only

NODE_ENV=production
HOST=0.0.0.0
PORT=8787

AUTH_REQUIRED=true
AUTH_ALLOW_INSECURE=false
PLATFORM_API_TOKEN=DEGISTIR_UZUN_RASTGELE_TOKEN_MIN_24

# Docker Compose postgres
POSTGRES_USER=petfix
POSTGRES_PASSWORD=DEGISTIR_GUVENLI_SIFRE
POSTGRES_DB=petfix_ops

OPS_POSTGRES_URL=postgresql://petfix:DEGISTIR_GUVENLI_SIFRE@postgres:5432/petfix_ops
OPS_PUBLIC_API_BASE_URL=https://api.petfix.com.tr
OPS_SHADOW_MODE_DEFAULT=false
OPS_IN_PROCESS_POLL_ENABLED=true
OPS_IN_PROCESS_POLL_INTERVAL_MINUTES=2
OPS_IN_PROCESS_POLL_GETIR_DAYS=1
OPS_IN_PROCESS_POLL_TGO_LIMIT=50

# Firebase Cloud Messaging — aşağıdakilerden biri yeterli:
# FCM_SERVER_KEY=AAAA...   (Legacy server key)
# FCM_SERVICE_ACCOUNT_PATH=/opt/petfix/secrets/fcm-service-account.json
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  (tek satır, tercih edilmez)

# Webhook doğrulama — production'da zorunlu
YEMEKSEPETI_WEBHOOK_SECRET=DEGISTIR_WEBHOOK_SECRET
WEBHOOK_VERIFY_DISABLED=false

# Yemeksepeti Partner API
YEMEKSEPETI_CLIENT_ID=
YEMEKSEPETI_CLIENT_SECRET=
YEMEKSEPETI_VENDOR_ID=
YEMEKSEPETI_CHAIN_ID=
# Partner Portal sayısal mağaza ID (opsiyonel — geçmiş sipariş backfill)
YEMEKSEPETI_STORE_ID=
# Harici İş Ortağı Yapılandırma Kimliği (external_partner_config_id)
YEMEKSEPETI_EXTERNAL_PARTNER_CONFIG_ID=
# Ek vendor/store id listesi (virgülle ayrılmış)
YEMEKSEPETI_VENDOR_IDS=

# Getir Çarşı
GETIR_SHOP_ID=
GETIR_API_USERNAME=
GETIR_API_PASSWORD=
GETIR_API_INITIAL_PASSWORD=
GETIR_API_BASE_URL=https://locals-integration-api-gateway.artisan.getirapi.com
GETIR_API_ENV=prod
GETIR_WEBHOOK_SECRET=
GETIR_API_KEY=

# Uber / Trendyol GO
UBER_EATS_SUPPLIER_ID=
UBER_EATS_API_KEY=
UBER_EATS_API_SECRET=
UBER_EATS_STORE_ID=

# Ops yazma bayrakları — shadow sonrası açılır
FF_CHANNEL_STATUS_WRITE=false
FF_BENIMPOS_SALE_WRITE=false
FF_STOCK_PUSH=false

BENIMPOS_BRANCH_ID=
BENIMPOS_API_URL=https://dev.benimpos.com/api
BENIMPOS_API_KEY=
BENIMPOS_SECRET_KEY=

PRODUCT_MATCHING_ENABLED=true
PRODUCT_MATCHING_MODE=hybrid
# Production: dual-write kapalı — restart'ta ağır I/O ve OOM riskini azaltır
SQLITE_DUAL_WRITE=false
DB_READ_BACKEND=json

# Opsiyonel şifreleme anahtarı (≥32 karakter)
ENCRYPTION_KEY=

# Trendyol BuyBox yalnızca petfix-marketplace reposunda — VPS'te gerekmez.
# Yerel: live-buybox-worker + .env içindeki TRENDYOL_* değerlerini kullanın.
