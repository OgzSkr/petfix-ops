# PetFix Production — sunucuda .env.production olarak kopyalayın
# cp .env.production.example .env.production

NODE_ENV=production
HOST=0.0.0.0
PORT=8787

AUTH_REQUIRED=true
AUTH_ALLOW_INSECURE=false
PLATFORM_API_TOKEN=DEGISTIR_UZUN_RASTGELE_TOKEN_MIN_24

# Docker Compose postgres
POSTGRES_USER=petfix
POSTGRES_PASSWORD=DEGISTIR_GUVENLI_SIFRE
POSTGRES_DB=petfix_ops

OPS_POSTGRES_URL=postgresql://petfix:DEGISTIR_GUVENLI_SIFRE@postgres:5432/petfix_ops
OPS_PUBLIC_API_BASE_URL=https://api.petfix.com.tr
OPS_SHADOW_MODE_DEFAULT=true

# Webhook doğrulama — production'da zorunlu
YEMEKSEPETI_WEBHOOK_SECRET=DEGISTIR_WEBHOOK_SECRET
WEBHOOK_VERIFY_DISABLED=false

# Yemeksepeti Partner API
YEMEKSEPETI_CLIENT_ID=
YEMEKSEPETI_CLIENT_SECRET=
YEMEKSEPETI_VENDOR_ID=
YEMEKSEPETI_CHAIN_ID=

# Getir (henüz opsiyonel)
GETIR_API_KEY=

# Uber / Trendyol GO
UBER_EATS_SUPPLIER_ID=
UBER_EATS_API_KEY=
UBER_EATS_API_SECRET=
UBER_EATS_STORE_ID=

# Ops yazma bayrakları — shadow sonrası açılır
FF_CHANNEL_STATUS_WRITE=false
FF_BENIMPOS_SALE_WRITE=false
FF_STOCK_PUSH=false

BENIMPOS_BRANCH_ID=
BENIMPOS_API_URL=https://dev.benimpos.com/api
BENIMPOS_API_KEY=
BENIMPOS_SECRET_KEY=

PRODUCT_MATCHING_MODE=strict
SQLITE_DUAL_WRITE=true
DB_READ_BACKEND=json

# Opsiyonel şifreleme anahtarı (≥32 karakter)
ENCRYPTION_KEY=
