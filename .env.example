# PetFix Ops — local ve production varsayılanı ops-only
# Pazaryeri: ../petfix-marketplace (:8788)
DEPLOY_PROFILE=ops-only

NODE_ENV=development
HOST=127.0.0.1
PORT=8787

# Auth — development'ta AUTH_ALLOW_INSECURE=true kullanılabilir
AUTH_ALLOW_INSECURE=false
PLATFORM_API_TOKEN=

# Ops PostgreSQL
OPS_POSTGRES_URL=postgresql://petfix:petfix@127.0.0.1:5433/petfix_ops
OPS_PUBLIC_API_BASE_URL=http://127.0.0.1:8787
OPS_SHADOW_MODE_DEFAULT=true

# Ops kanal poll — in-process zamanlayıcı (systemd/cron yanında; varsayılan kapalı)
# OPS_IN_PROCESS_POLL_ENABLED=true
# OPS_IN_PROCESS_POLL_INTERVAL_MINUTES=2
# OPS_IN_PROCESS_POLL_YS_DAYS=14
# OPS_IN_PROCESS_POLL_TGO_LIMIT=50

# Kanal secret şifreleme (Faz 4a) — ENCRYPTION_KEY tanımlıysa Ops Hub DB'de şifreli saklanır
# ENCRYPTION_KEY=  # en az 32 karakter
# CHANNEL_SECRETS_ENCRYPTED=true  # zorla aç/kapat (varsayılan: ENCRYPTION_KEY varsa açık)

# Tenant / şube RBAC (Faz 4b)
# OPS_DEFAULT_TENANT_SLUG=main
# OPS_DEFAULT_TENANT_NAME=PetFix
# OPS_RBAC_SUBJECT_KEY=platform
# OPS_BRANCH_ID_REQUIRED=false  # true ise API isteklerinde şube seçimi zorunlu

# Yemeksepeti
YEMEKSEPETI_CLIENT_ID=
YEMEKSEPETI_CLIENT_SECRET=
YEMEKSEPETI_VENDOR_ID=
YEMEKSEPETI_CHAIN_ID=
YEMEKSEPETI_WEBHOOK_SECRET=

# Getir Çarşı
GETIR_SHOP_ID=
GETIR_API_USERNAME=
GETIR_API_PASSWORD=
GETIR_API_INITIAL_PASSWORD=
GETIR_API_BASE_URL=
GETIR_API_ENV=dev
GETIR_WEBHOOK_SECRET=
GETIR_API_KEY=

# Trendyol Pazaryeri (BuyBox + sipariş API)
TRENDYOL_SELLER_ID=
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=
TRENDYOL_ENVIRONMENT=PROD

# Uber / Trendyol GO
UBER_EATS_SUPPLIER_ID=
UBER_EATS_API_KEY=
UBER_EATS_API_SECRET=
UBER_EATS_STORE_ID=

# BenimPOS
BENIMPOS_BRANCH_ID=
BENIMPOS_API_URL=https://dev.benimpos.com/api
BENIMPOS_API_KEY=
BENIMPOS_SECRET_KEY=
# Toplama bitince otomatik kasa satışı (varsayılan kapalı)
BENIMPOS_AUTO_SALE=false

# BenimPOS stok → kanal menüsü otomatik senkron (varsayılan kapalı)
STOCK_AUTO_SYNC_ENABLED=false
STOCK_AUTO_SYNC_INTERVAL_MINUTES=15
STOCK_AUTO_SYNC_MAX_ITEMS=500

PRODUCT_MATCHING_MODE=legacy
PRODUCT_MATCHING_ENABLED=false
SQLITE_DUAL_WRITE=true
DB_READ_BACKEND=json
