{
  "name": "petfix-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev:local": "PORT=8899 node server.js",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 stop ecosystem.config.cjs",
    "smoke": "node scripts/dev/smoke-test.js",
    "test": "node --test test/*.test.js",
    "parity": "node scripts/maintenance/check-db-parity.js",
    "maintain:trim-snapshots": "echo 'deprecated — marketplace repo only'",
    "maintain:purge-marketplace": "node scripts/maintenance/purge-marketplace-local-data.js",
    "maintain:split-db": "node scripts/maintenance/split-local-db.js",
    "maintain:vps-cleanup": "bash scripts/maintenance/vps-ops-only-cleanup.sh",
    "maintain:workbench-index": "node scripts/maintenance/rebuild-workbench-index.js",
    "ops:migrate": "node scripts/migrations/ops-hub-migrate.js",
    "ops:seed-mock": "node scripts/seed/ops-hub-seed-mock.js",
    "ops:seed-integrations": "node scripts/seed/ops-hub-seed-integrations.js",
    "ops:sync-tgo": "node scripts/ops-hub-sync-tgo.js",
    "ops:sync-ys": "node scripts/ops-hub-sync-ys.js",
    "ops:ys-backfill": "node scripts/ys-backfill-orders-by-id.js",
    "ops:ys-portal-sync": "node scripts/ys-portal-sync-orders-cdp.js",
    "ops:ys-portal-ingest": "node scripts/ys-portal-ingest-json.js",
    "ops:ys-enrich-lines": "node scripts/ys-enrich-order-lines.js",
    "ops:ys-portal-details": "node scripts/ys-portal-backfill-order-details-cdp.js",
    "ops:ys-portal-details-ingest": "node scripts/ys-portal-ingest-order-details-json.js",
    "ops:stock-sync": "node scripts/ops-hub-stock-sync.js",
    "ops:poll": "node scripts/ops-hub-poll.js",
    "ops:webhook-test-ys": "node scripts/dev/ops-hub-webhook-test-ys.js",
    "ops:g6-cancel-test": "node scripts/dev/ops-hub-g6-cancel-test.js",
    "ops:up": "docker compose --env-file deploy/compose.env -f docker-compose.ops-api.yml up -d --build",
    "ops:down": "docker compose --env-file deploy/compose.env -f docker-compose.ops-api.yml down",
    "ops:bootstrap": "bash scripts/ops-bootstrap.sh",
    "ops:verify-deploy": "node scripts/maintenance/ops-verify-deploy.js",
    "ops:webhook-setup": "node scripts/dev/ops-print-webhook-setup.js",
    "ops:ys-portal-webhook": "node scripts/ys-portal-webhook-cdp.js",
    "ops:ys-portal-webhook:catalog": "node scripts/ys-portal-webhook-cdp.js --catalog-only",
    "ops:tunnel": "bash scripts/ops-tunnel.sh",
    "ops:deploy-vps": "bash scripts/ops-deploy-vps.sh",
    "prod:up": "docker compose -f compose.prod.yml --env-file .env.production up -d --build",
    "prod:down": "docker compose -f compose.prod.yml --env-file .env.production down",
    "prod:deploy": "bash scripts/deploy-production.sh",
    "prod:backfill-ys-payload": "node scripts/ops-backfill-ys-payload.js",
    "prod:backfill-order-line-costs": "node scripts/ops-backfill-order-line-costs.js",
    "ops:autopilot": "node scripts/ops-autopilot.js",
    "ops:prod-daily-sync": "node scripts/ops-prod-daily-sync.js",
    "ops:install-poll": "bash scripts/ops-install-poll-agent.sh",
    "ops:install-api-watchdog": "bash scripts/ops-install-api-watchdog.sh",
    "ops:install-tunnel": "bash scripts/ops-install-tunnel-agent.sh",
    "ops:pg-up": "docker compose --env-file deploy/compose.env -f docker-compose.ops.yml up -d",
    "ops:pg-down": "docker compose -f docker-compose.ops.yml down",
    "check": "node --check server.js && node --check lib/platform/app.js && node --check lib/platform/routes/handler.js && node --check lib/platform/routes/page-routes.js && node --check lib/platform/routes/api-routes.js && node --check lib/platform/views/pages.js && node --check lib/platform/services/ops.js && node --check lib/db/store.js && node --check lib/db/parity.js && node --check lib/channels/credentials.js && node --check scripts/dev/smoke-test.js"
  },
  "dependencies": {
    "pg": "^8.16.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18"
  }
}
